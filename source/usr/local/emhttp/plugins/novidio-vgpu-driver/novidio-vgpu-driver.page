<?php
/* novidio-vgpu-driver settings page
 * - status overview (driver / services / GPUs)
 * - vGPU device manager (replaces the old user-scripts workflow)
 * - settings + profile_override.toml editor
 */

$vgpu_plugin  = "novidio-vgpu-driver";
$vgpu_emhttp  = "/usr/local/emhttp/plugins/$vgpu_plugin";
$vgpu_cfgdir  = "/boot/config/plugins/$vgpu_plugin";
$vgpu_devcfg  = "$vgpu_cfgdir/vgpu-devices.cfg";
$vgpu_usercfg = "/boot/config/nvidia-vgpu";
$vgpu_rc      = "$vgpu_emhttp/scripts/rc.vgpu";
$override_toml = "$vgpu_usercfg/profile_override.toml";

function vgpu_setting($key, $default = "") {
  // no parse_ini_file: it mangles unquoted true/false into "1"/""
  global $vgpu_cfgdir;
  $file = "$vgpu_cfgdir/settings.cfg";
  if (is_file($file)) {
    foreach (file($file, FILE_IGNORE_NEW_LINES) as $line) {
      if (strpos($line, "$key=") === 0) return substr($line, strlen($key) + 1);
    }
  }
  return $default;
}

function vgpu_set_setting($key, $value) {
  global $vgpu_cfgdir;
  $file = "$vgpu_cfgdir/settings.cfg";
  $lines = is_file($file) ? file($file, FILE_IGNORE_NEW_LINES) : [];
  $found = false;
  foreach ($lines as $i => $line) {
    if (strpos($line, "$key=") === 0) { $lines[$i] = "$key=$value"; $found = true; }
  }
  if (!$found) $lines[] = "$key=$value";
  file_put_contents($file, implode("\n", $lines)."\n");
}

function vgpu_devices() {
  global $vgpu_devcfg;
  $out = [];
  if (is_file($vgpu_devcfg)) {
    foreach (file($vgpu_devcfg, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
      if ($line === '' || $line[0] === '#') continue;
      $p = explode('|', $line);
      if (count($p) >= 3) $out[] = ['uuid' => $p[0], 'pci' => $p[1], 'type' => $p[2]];
    }
  }
  return $out;
}

function vgpu_save_devices($devices) {
  global $vgpu_devcfg;
  $lines = ["# managed by the Novidio vGPU plugin page - UUID|PCI|TYPE"];
  foreach ($devices as $d) $lines[] = "{$d['uuid']}|{$d['pci']}|{$d['type']}";
  file_put_contents($vgpu_devcfg, implode("\n", $lines)."\n");
}

$valid_uuid = '/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i';
$valid_pci  = '/^[0-9a-f]{4}:[0-9a-f]{2}:[0-9a-f]{2}\.[0-9a-f]$/i';
$valid_type = '/^[A-Za-z0-9_.\-]+$/';

/* ---------- handle actions ---------- */
$vgpu_msg = ""; $vgpu_err = "";
if (!empty($_POST['vgpu_action'])) {
  $uuid  = isset($_POST['uuid'])  ? strtolower(trim($_POST['uuid'])) : '';
  $pci   = isset($_POST['pci'])   ? strtolower(trim($_POST['pci']))  : '';
  $mtype = isset($_POST['mtype']) ? trim($_POST['mtype'])            : '';
  switch ($_POST['vgpu_action']) {
    case 'add_device':
      if (!preg_match($valid_uuid, $uuid))      $vgpu_err = "Invalid UUID.";
      elseif (!preg_match($valid_pci, $pci))    $vgpu_err = "Invalid PCI address.";
      elseif (!preg_match($valid_type, $mtype)) $vgpu_err = "Invalid mdev type.";
      else {
        $devices = vgpu_devices();
        foreach ($devices as $d) if ($d['uuid'] === $uuid) $vgpu_err = "A vGPU with this UUID already exists.";
        if (!$vgpu_err) {
          $devices[] = ['uuid' => $uuid, 'pci' => $pci, 'type' => $mtype];
          vgpu_save_devices($devices);
          shell_exec("mdevctl define -u ".escapeshellarg($uuid)." -p ".escapeshellarg($pci)." --type ".escapeshellarg($mtype)." 2>&1");
          $start_out = shell_exec("mdevctl start -u ".escapeshellarg($uuid)." 2>&1");
          $vgpu_msg = "vGPU $uuid added.";
          if (is_dir("/sys/bus/mdev/devices/$uuid")) $vgpu_msg .= " Device is running.";
          else $vgpu_err = "Device saved but could not be started: ".trim($start_out);
        }
      }
      break;
    case 'remove_device':
      if (preg_match($valid_uuid, $uuid)) {
        shell_exec("mdevctl stop -u ".escapeshellarg($uuid)." 2>/dev/null");
        shell_exec("mdevctl undefine -u ".escapeshellarg($uuid)." 2>/dev/null");
        vgpu_save_devices(array_values(array_filter(vgpu_devices(), fn($d) => $d['uuid'] !== $uuid)));
        $vgpu_msg = "vGPU $uuid removed.";
      }
      break;
    case 'start_device':
      if (preg_match($valid_uuid, $uuid)) {
        foreach (vgpu_devices() as $d) if ($d['uuid'] === $uuid) {
          shell_exec("mdevctl define -u ".escapeshellarg($d['uuid'])." -p ".escapeshellarg($d['pci'])." --type ".escapeshellarg($d['type'])." 2>/dev/null");
          $start_out = shell_exec("mdevctl start -u ".escapeshellarg($d['uuid'])." 2>&1");
          if (is_dir("/sys/bus/mdev/devices/$uuid")) $vgpu_msg = "vGPU $uuid started.";
          else $vgpu_err = "Could not start $uuid: ".trim($start_out);
        }
      }
      break;
    case 'stop_device':
      if (preg_match($valid_uuid, $uuid)) {
        shell_exec("mdevctl stop -u ".escapeshellarg($uuid)." 2>&1");
        $vgpu_msg = "vGPU $uuid stopped.";
      }
      break;
    case 'save_settings':
      $unlock = (isset($_POST['unlock']) && $_POST['unlock'] === 'true') ? 'true' : 'false';
      $upd    = (isset($_POST['update_check']) && $_POST['update_check'] === 'true') ? 'true' : 'false';
      $unlock_changed = (vgpu_setting('unlock', 'false') !== $unlock);
      vgpu_set_setting('unlock', $unlock);
      shell_exec("$vgpu_emhttp/include/exec.sh change_update_check ".escapeshellarg($upd));
      $vgpu_msg = "Settings saved.";
      if ($unlock_changed) $vgpu_msg .= " The vGPU unlock setting takes effect after 'Restart vGPU Services'.";
      break;
    case 'save_override':
      if (!is_dir($vgpu_usercfg)) mkdir($vgpu_usercfg, 0755, true);
      $content = str_replace("\r", "", $_POST['override_content'] ?? '');
      file_put_contents($override_toml, $content);
      shell_exec(escapeshellarg($vgpu_rc)." apply 2>/dev/null");
      $vgpu_msg = "profile_override.toml saved. Restart the vGPU services (and your VM) for changes to take effect.";
      break;
  }
}

/* ---------- gather status ---------- */
shell_exec("$vgpu_emhttp/include/exec.sh update");

$kernel      = trim(shell_exec("uname -r"));
$unraid_v    = trim(shell_exec("cut -d '\"' -f2 /etc/unraid-version"));
$installed_v = trim(shell_exec("modinfo -F version nvidia 2>/dev/null | head -1"));
$loaded_v    = trim(@file_get_contents("/sys/module/nvidia/version"));
$latest_v    = trim(shell_exec("$vgpu_emhttp/include/exec.sh get_latest_version"));
$mgr_running = trim(shell_exec("pgrep -x nvidia-vgpu-mgr 2>/dev/null")) !== '';
$update_avail = ($latest_v && $installed_v && version_compare($latest_v, $installed_v, '>'));

/* NVIDIA GPUs + their mdev types straight from sysfs */
$gpus = []; $gpu_types = []; $types_present = false;
foreach (glob("/sys/bus/pci/devices/*") as $dev) {
  $vendor = trim(@file_get_contents("$dev/vendor"));
  $class  = trim(@file_get_contents("$dev/class"));
  if ($vendor !== "0x10de" || strpos($class, "0x03") !== 0) continue;
  $pci  = basename($dev);
  $name = trim(shell_exec("lspci -s ".escapeshellarg(substr($pci, 5))." 2>/dev/null | cut -d ':' -f3-"));
  $gpus[$pci] = $name ?: "NVIDIA GPU";
  $gpu_types[$pci] = [];
  foreach (glob("$dev/mdev_supported_types/*") as $tdir) {
    $types_present = true;
    // description holds the profile parameters, e.g.
    // "num_heads=4, frl_config=60, framebuffer=1024M, max_resolution=5120x2880, max_instance=8"
    $info = [];
    foreach (preg_split('/,\s*/', trim(@file_get_contents("$tdir/description"))) as $kv) {
      $p = explode('=', $kv, 2);
      if (count($p) == 2) $info[trim($p[0])] = trim($p[1]);
    }
    $gpu_types[$pci][] = [
      'type'  => basename($tdir),
      'name'  => trim(@file_get_contents("$tdir/name")),
      'avail' => trim(@file_get_contents("$tdir/available_instances")),
      'fb'    => $info['framebuffer']    ?? '',
      'heads' => $info['num_heads']      ?? '',
      'res'   => $info['max_resolution'] ?? '',
      'frl'   => $info['frl_config']     ?? '',
      'max'   => $info['max_instance']   ?? '',
    ];
  }
  usort($gpu_types[$pci], fn($a, $b) => strnatcmp($a['name'], $b['name']));
}

$devices = vgpu_devices();
foreach ($devices as &$d) $d['running'] = is_dir("/sys/bus/mdev/devices/{$d['uuid']}");
unset($d);

$unlock_on    = vgpu_setting('unlock', 'false') === 'true';
$upd_check_on = vgpu_setting('update_check', 'true') === 'true';
$override_content = is_file($override_toml) ? file_get_contents($override_toml) : "";
$xml_override_present = is_file("$vgpu_usercfg/vgpuConfig.xml");
$new_uuid = trim(shell_exec("uuidgen 2>/dev/null")) ?: sprintf('%04x%04x-%04x-4%03x-%04x-%04x%04x%04x',
  mt_rand(0,0xffff), mt_rand(0,0xffff), mt_rand(0,0xffff), mt_rand(0,0xfff),
  mt_rand(0x8000,0xbfff), mt_rand(0,0xffff), mt_rand(0,0xffff), mt_rand(0,0xffff));
?>

<script>
// avoid re-posting actions on page refresh
if (window.history.replaceState) window.history.replaceState(null, null, window.location.href);

var gpuTypes = <?= json_encode($gpu_types) ?>;

function esc(s) {
  var d = document.createElement('div');
  d.innerText = s == null ? '' : String(s);
  return d.innerHTML;
}

function fillTypes() {
  var pci = document.getElementById('add_pci').value;
  var box = document.getElementById('type_table');
  var types = gpuTypes[pci] || [];
  if (!types.length) {
    box.innerHTML = '<i>No mdev types available on this GPU.</i>';
    return;
  }
  var html = '<table class="vgpu-table vgpu-ptable">' +
    '<tr><th></th><th>Profile</th><th>Type</th><th>Framebuffer</th><th>Displays</th><th>Max Resolution</th><th>FRL</th><th>Free</th></tr>';
  types.forEach(function(t, i) {
    var soldout = (parseInt(t.avail, 10) || 0) < 1;
    html += '<tr class="vgpu-prow' + (soldout ? ' vgpu-soldout' : '') + '" data-row="' + i + '">' +
      '<td><input type="radio" name="mtype" value="' + esc(t.type) + '"' + (soldout ? ' disabled' : '') + '></td>' +
      '<td><b>' + esc(t.name) + '</b></td>' +
      '<td>' + esc(t.type) + '</td>' +
      '<td>' + esc(t.fb) + '</td>' +
      '<td>' + esc(t.heads) + '</td>' +
      '<td>' + esc(t.res) + '</td>' +
      '<td>' + esc(t.frl ? t.frl + ' fps' : '') + '</td>' +
      '<td>' + esc(t.avail + (t.max ? ' / ' + t.max : '')) + '</td>' +
      '</tr>';
  });
  html += '</table>';
  box.innerHTML = html;
  // whole row selects the radio; highlight the selected row
  box.querySelectorAll('tr.vgpu-prow').forEach(function(row) {
    row.addEventListener('click', function() {
      var radio = row.querySelector('input[type=radio]');
      if (!radio || radio.disabled) return;
      radio.checked = true;
      box.querySelectorAll('tr.vgpu-prow').forEach(function(r) { r.classList.remove('vgpu-selected'); });
      row.classList.add('vgpu-selected');
    });
  });
}

function genUUID() {
  var u = ([1e7]+-1e3+-4e3+-8e3+-1e11).replace(/[018]/g, c =>
    (c ^ crypto.getRandomValues(new Uint8Array(1))[0] & 15 >> c / 4).toString(16));
  document.getElementById('add_uuid').value = u;
}

function vgpuAction(action, uuid) {
  var f = document.getElementById('vgpu_action_form');
  f.vgpu_action.value = action;
  f.uuid.value = uuid;
  if (action === 'remove_device' && !confirm('Remove this vGPU device? Make sure no VM is using it.')) return;
  f.submit();
}

function toggleXML(id) {
  var el = document.getElementById(id);
  el.style.display = (el.style.display === 'none') ? 'block' : 'none';
}

function copyXML(id) {
  var txt = document.getElementById(id).innerText;
  navigator.clipboard.writeText(txt).then(function(){ /* ok */ });
}

function restartServices() {
  openBox('/plugins/novidio-vgpu-driver/include/exec.sh&arg1=restart_services', 'Restarting vGPU Services', 600, 900, true);
}

function updateDriver() {
  openBox('/plugins/novidio-vgpu-driver/include/exec.sh&arg1=update_driver&arg2=latest', 'Updating Nvidia vGPU Driver', 600, 900, true);
}
</script>

